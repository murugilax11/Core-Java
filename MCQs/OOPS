//1. The constructor of A calls print() before B's fields are initialized, so x is 0.
class A {
   A() { print(); }
   void print() { System.out.println("A"); }
}
class B extends A {
   int x = 10;
   void print() { System.out.println(x); }
}
public class mcq_oops {
   public static void main(String[] args) {
       new B();
   }
}


//2. Compilation error
//Explanation: Can't override static method with instance method.
class A {
   static void show() {}
}
class B extends A {
   void show() {}
}


//3. Compilation error
//Explanation: Must override show() in A to resolve conflict
interface I1 { default void show() { System.out.println("I1"); } }
interface I2 { default void show() { System.out.println("I2"); } }
class A implements I1, I2 {}


//4.  object
//Explanation: Method resolution happens at compile-time based on reference type (A).
class A { void show(Object o) { System.out.println("object"); } }
class B extends A { void show(String s) { System.out.println("str"); } }
public class mcq_oops {
   public static void main(String[] args) {
      A obj= new B();
       obj.show("hello");
   }
}


