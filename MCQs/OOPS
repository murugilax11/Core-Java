//6. no relation
//Explanation: Private methods aren't inherited; B's show() isn't overriding A's.
class A { private void show() {} }
class B extends A { void show() {} }


//7. AB
//Every constructor in Java implicitly calls the superclass constructor first
//        (i.e., super();) if you don’t explicitly call another constructor.
abstract class A {
A() { System.out.print("A "); }
abstract void show();
}
class B extends A {
B() { System.out.print("B "); }
void show() {}
}


