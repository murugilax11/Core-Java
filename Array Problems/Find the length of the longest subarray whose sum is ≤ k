public class longest_sub_sum {
    public static void main(String[] args) {
        int[] arr = new int[]{2, 1, 5, 1, 3};
        int k =7;
        int left =0;
        int max =0;
        int sum =0;
        for(int i =0; i <arr.length;i++){
             sum += arr[i];
             while(sum>k){
                 sum -= arr[left];
                 left++;
             }
             max = Math.max(max,i-left+1);

        }
        System.out.println(max);
    }
}
